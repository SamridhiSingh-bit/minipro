<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DebateX — Room <%= roomId %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:ital@0;1&display=swap" rel="stylesheet">
  <script src="/socket.io/socket.io.js"></script>
  <style>
    :root {
      --red: #E63946;
      --dark: #0a0a0a;
      --mid: #141414;
      --card: #1a1a1a;
      --border: #2a2a2a;
      --text: #f0ede8;
      --muted: #777;
      --gold: #C9A84C;
      --green: #2ECC71;
      --blue: #4A90E2;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; }
    body {
      background: var(--dark);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      display: flex;
      flex-direction: column;
    }

    nav {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32px;
      height: 64px;
      border-bottom: 1px solid var(--border);
      background: rgba(10,10,10,0.98);
      z-index: 10;
    }
    .logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 4px;
    }
    .logo span { color: var(--red); }
    .room-info {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .room-code {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 3px;
      color: var(--gold);
    }
    .copy-btn {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.75rem;
      letter-spacing: 1px;
      padding: 4px 10px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .copy-btn:hover { border-color: var(--gold); color: var(--gold); }
    .status-indicator {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.75rem;
      letter-spacing: 1px;
      color: var(--muted);
    }
    .status-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--muted);
    }
    .status-dot.live { background: var(--green); animation: pulse 2s infinite; }
    .status-dot.waiting { background: var(--gold); animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .nav-right { display: flex; align-items: center; gap: 12px; }
    .back-btn {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      padding: 6px 14px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .back-btn:hover { border-color: var(--red); color: var(--red); }

    /* Layout */
    .arena {
      flex: 1;
      display: grid;
      grid-template-columns: 260px 1fr 260px;
      overflow: hidden;
    }

    /* Sidebar */
    .sidebar {
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: var(--mid);
    }
    .sidebar-right { border-right: none; border-left: 1px solid var(--border); }
    .sidebar-header {
      padding: 20px;
      border-bottom: 1px solid var(--border);
      font-size: 0.65rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
    }
    .sidebar-content { padding: 20px; flex: 1; overflow-y: auto; }

    .debater-card {
      background: var(--card);
      border: 1px solid var(--border);
      padding: 16px;
      margin-bottom: 12px;
      transition: border-color 0.2s;
    }
    .debater-card.speaking { border-color: var(--red); }
    .debater-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 2px;
      margin-bottom: 4px;
    }
    .debater-role {
      font-size: 0.7rem;
      letter-spacing: 1px;
      color: var(--muted);
    }
    .debater-badge {
      display: inline-block;
      font-size: 0.65rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 2px 8px;
      margin-top: 8px;
    }
    .badge-for { background: rgba(46,204,113,0.15); color: var(--green); border: 1px solid rgba(46,204,113,0.3); }
    .badge-against { background: rgba(230,57,70,0.15); color: var(--red); border: 1px solid rgba(230,57,70,0.3); }
    .badge-you { background: rgba(74,144,226,0.15); color: var(--blue); border: 1px solid rgba(74,144,226,0.3); }

    .empty-debater {
      border: 1px dashed var(--border);
      padding: 16px;
      margin-bottom: 12px;
      text-align: center;
      color: var(--muted);
      font-size: 0.85rem;
    }
    .waiting-ring {
      width: 32px; height: 32px;
      border: 2px solid var(--border);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto 8px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .topic-box {
      background: var(--dark);
      border: 1px solid var(--border);
      padding: 16px;
      margin-top: 16px;
    }
    .topic-label {
      font-size: 0.65rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }
    .topic-text {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--text);
    }

    /* Chat */
    .chat-area {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .topic-banner {
      flex-shrink: 0;
      background: rgba(201,168,76,0.05);
      border-bottom: 1px solid rgba(201,168,76,0.15);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      display: none;
    }
    .topic-banner.visible { display: flex; }
    .topic-banner-label {
      font-size: 0.65rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold);
      white-space: nowrap;
    }
    .topic-banner-text {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 0.9rem;
      color: var(--text);
    }

    .messages {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      scroll-behavior: smooth;
    }
    .messages::-webkit-scrollbar { width: 4px; }
    .messages::-webkit-scrollbar-track { background: transparent; }
    .messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .msg {
      display: flex;
      flex-direction: column;
      max-width: 80%;
      animation: msgIn 0.3s ease;
    }
    @keyframes msgIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .msg.mine { align-self: flex-end; align-items: flex-end; }
    .msg.theirs { align-self: flex-start; }
    .msg.judge { align-self: center; max-width: 90%; }
    .msg.system { align-self: center; max-width: 90%; }

    .msg-header {
      font-size: 0.7rem;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 4px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .msg-username { font-weight: 600; color: var(--text); }
    .msg.mine .msg-username { color: var(--blue); }
    .msg.theirs .msg-username { color: var(--red); }
    .msg.judge .msg-username { color: var(--gold); }

    .msg-bubble {
      padding: 12px 16px;
      font-size: 0.95rem;
      line-height: 1.6;
      border-radius: 0;
    }
    .msg.mine .msg-bubble {
      background: rgba(74,144,226,0.12);
      border: 1px solid rgba(74,144,226,0.2);
    }
    .msg.theirs .msg-bubble {
      background: rgba(230,57,70,0.08);
      border: 1px solid rgba(230,57,70,0.15);
    }
    .msg.judge .msg-bubble {
      background: rgba(201,168,76,0.06);
      border: 1px solid rgba(201,168,76,0.2);
      font-size: 0.9rem;
      white-space: pre-wrap;
    }
    .msg.system .msg-bubble {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      text-align: center;
      font-size: 0.8rem;
      color: var(--muted);
    }
    .verdict-bubble {
      background: rgba(201,168,76,0.08) !important;
      border: 1px solid rgba(201,168,76,0.3) !important;
      white-space: pre-wrap;
    }

    /* Input */
    .input-area {
      flex-shrink: 0;
      border-top: 1px solid var(--border);
      padding: 16px 24px;
      background: var(--mid);
    }
    .input-row {
      display: flex;
      gap: 12px;
      align-items: flex-end;
    }
    .msg-input {
      flex: 1;
      background: var(--dark);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      padding: 12px 16px;
      outline: none;
      resize: none;
      min-height: 48px;
      max-height: 120px;
      transition: border-color 0.2s;
    }
    .msg-input:focus { border-color: var(--red); }
    .msg-input:disabled { opacity: 0.4; cursor: not-allowed; }
    .send-btn {
      background: var(--red);
      border: none;
      color: white;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 2px;
      padding: 0 24px;
      height: 48px;
      cursor: pointer;
      transition: opacity 0.2s;
      white-space: nowrap;
    }
    .send-btn:hover { opacity: 0.85; }
    .send-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .end-btn {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      padding: 0 16px;
      height: 48px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .end-btn:hover { border-color: var(--red); color: var(--red); }
    .end-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .spectator-note {
      text-align: center;
      font-size: 0.8rem;
      color: var(--muted);
      padding: 12px;
    }

    /* Overlay states */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.85);
      backdrop-filter: blur(8px);
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 20px;
      text-align: center;
      padding: 24px;
    }
    .overlay.hidden { display: none; }
    .overlay-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      letter-spacing: 4px;
    }
    .overlay-sub { color: var(--muted); font-size: 1rem; max-width: 400px; line-height: 1.6; }
    .share-box {
      background: var(--card);
      border: 1px solid var(--border);
      padding: 24px 40px;
    }
    .share-label { font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
    .share-code {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      letter-spacing: 8px;
      color: var(--gold);
    }
    .vs-badge {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 4px;
      color: var(--muted);
    }
    .debater-vs {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: 3px;
    }

    @media (max-width: 900px) {
      .arena { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }
  </style>
</head>
<body>
  <nav>
    <div class="logo">Debate<span>X</span></div>
    <div class="room-info">
      <span class="room-code"># <%= roomId %></span>
      <button class="copy-btn" onclick="copyCode()">Copy Code</button>
      <div class="status-indicator">
        <div class="status-dot waiting" id="status-dot"></div>
        <span id="status-text">Waiting</span>
      </div>
    </div>
    <div class="nav-right">
      <button class="back-btn" onclick="window.location.href='/lobby'">← Lobby</button>
    </div>
  </nav>

  <!-- Waiting overlay -->
  <div class="overlay" id="waiting-overlay">
    <div class="overlay-title">Waiting for<br><span style="color:var(--red)">Opponent</span></div>
    <p class="overlay-sub">Share this code with your opponent. The debate starts when two debaters join.</p>
    <div class="share-box">
      <div class="share-label">Room Code</div>
      <div class="share-code"><%= roomId %></div>
    </div>
    <p style="color:var(--muted);font-size:0.8rem;">You are debater 1. Your opponent's slot is open.</p>
  </div>

  <!-- Starting overlay -->
  <div class="overlay hidden" id="starting-overlay">
    <div style="width:48px;height:48px;border:3px solid var(--border);border-top-color:var(--red);border-radius:50%;animation:spin 1s linear infinite;"></div>
    <div class="overlay-title" style="font-size:2rem;">Generating<br><span style="color:var(--gold)">Topic</span></div>
    <p class="overlay-sub">The AI Judge is selecting today's debate topic...</p>
  </div>

  <div class="arena">
    <!-- Left sidebar: debaters -->
    <div class="sidebar">
      <div class="sidebar-header">Debaters</div>
      <div class="sidebar-content">
        <div id="debater-1-card" class="empty-debater">
          <div class="waiting-ring"></div>
          Waiting...
        </div>
        <div id="debater-2-card" class="empty-debater">
          <div class="waiting-ring"></div>
          Waiting...
        </div>
        <div class="topic-box" id="sidebar-topic" style="display:none">
          <div class="topic-label">⚖️ Today's Topic</div>
          <div class="topic-text" id="sidebar-topic-text"></div>
        </div>
      </div>
    </div>

    <!-- Chat -->
    <div class="chat-area">
      <div class="topic-banner" id="topic-banner">
        <span class="topic-banner-label">Topic</span>
        <span class="topic-banner-text" id="topic-banner-text"></span>
      </div>
      <div class="messages" id="messages"></div>
      <div class="input-area" id="input-area">
        <div id="debater-input">
          <div class="input-row">
            <textarea class="msg-input" id="msg-input" placeholder="Make your argument..." disabled rows="1" maxlength="1000"></textarea>
            <button class="end-btn" id="end-btn" onclick="endDebate()" disabled>End Debate</button>
            <button class="send-btn" id="send-btn" onclick="sendMessage()" disabled>Send</button>
          </div>
        </div>
        <div class="spectator-note" id="spectator-note" style="display:none">
          You are watching as a spectator
        </div>
      </div>
    </div>

    <!-- Right sidebar: judge info -->
<div class="sidebar sidebar-right">
      <div class="sidebar-header">Debate Stats</div>
      <div class="sidebar-content">
        <div style="margin-top:16px;background:var(--dark);border:1px solid var(--border);padding:16px;" id="msg-count-box">
          <div style="font-size:0.7rem;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;">Messages</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--text);" id="msg-count">0</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const roomId = '<%= roomId %>';
    const username = '<%= username %>';
    let role = 'spectator';
    let debateActive = false;
    let msgCount = 0;

    const socket = io();

    socket.emit('join-room', { roomId });

    socket.on('room-state', ({ room, role: myRole }) => {
      role = myRole;
      updateDebaters(room.debaters);
      if (room.topic) {
        showTopic(room.topic);
        debateActive = room.status === 'active';
      }
      // Render existing messages
      room.messages.forEach(msg => addMessage(msg, false));
      scrollToBottom();
      
      // Update UI based on state
      if (room.status === 'active') {
        hideWaiting();
        enableInput();
        updateJudgeStatus('Active — evaluating arguments');
        updateStatusDot('live', 'Live');
      } else if (room.status === 'finished') {
        hideWaiting();
        disableInput();
        updateJudgeStatus('Verdict delivered');
        updateStatusDot('', 'Ended');
      } else if (room.debaters.length === 2) {
        hideWaiting();
      }
    });

    socket.on('user-joined', ({ username: u, debaters }) => {
      updateDebaters(debaters);
      if (debaters.length < 2) {
        addSystemMessage(`${u} joined the room`);
      }
    });

    socket.on('debate-starting', ({ debaters }) => {
      document.getElementById('waiting-overlay').classList.add('hidden');
      document.getElementById('starting-overlay').classList.remove('hidden');
      updateDebaters(debaters);
    });

    socket.on('debate-started', ({ topic, judgeMessage }) => {
      document.getElementById('starting-overlay').classList.add('hidden');
      showTopic(topic);
      addMessage(judgeMessage, true);
      debateActive = true;
      enableInput();
      updateJudgeStatus('Active — evaluating arguments');
      updateStatusDot('live', 'Live');
    });

    socket.on('new-message', (msg) => {
      addMessage(msg, true);
    });

    socket.on('user-left', ({ username: u, debaters }) => {
      updateDebaters(debaters);
      addSystemMessage(`${u} left the debate`);
    });

    socket.on('debate-ending', () => {
      disableInput();
      updateJudgeStatus('Deliberating final verdict...');
      addSystemMessage('⚖️ The AI Judge is deliberating...');
    });

    socket.on('final-verdict', (msg) => {
      addMessage(msg, true);
      updateJudgeStatus('Verdict delivered');
      updateStatusDot('', 'Ended');
    });

    socket.on('error', (err) => {
      console.error(err);
    });

    function updateDebaters(debaters) {
      const d1 = document.getElementById('debater-1-card');
      const d2 = document.getElementById('debater-2-card');
      
      if (debaters[0]) {
        const isMe = debaters[0] === username;
        d1.className = 'debater-card';
        d1.innerHTML = `
          <div class="debater-name">${debaters[0]}</div>
          <div class="debater-role">Debater 1</div>
          <span class="debater-badge badge-for">FOR</span>
          ${isMe ? '<span class="debater-badge badge-you" style="margin-left:4px">You</span>' : ''}
        `;
      } else {
        d1.className = 'empty-debater';
        d1.innerHTML = '<div class="waiting-ring"></div>Waiting...';
      }

      if (debaters[1]) {
        const isMe = debaters[1] === username;
        d2.className = 'debater-card';
        d2.innerHTML = `
          <div class="debater-name">${debaters[1]}</div>
          <div class="debater-role">Debater 2</div>
          <span class="debater-badge badge-against">AGAINST</span>
          ${isMe ? '<span class="debater-badge badge-you" style="margin-left:4px">You</span>' : ''}
        `;
      } else {
        d2.className = 'empty-debater';
        d2.innerHTML = '<div class="waiting-ring"></div>Waiting...';
      }

      // Show waiting overlay if we're a debater with no opponent
      if (debaters.length < 2 && role === 'debater') {
        document.getElementById('waiting-overlay').classList.remove('hidden');
      }
    }

    function showTopic(topic) {
      document.getElementById('topic-banner-text').textContent = topic;
      document.getElementById('topic-banner').classList.add('visible');
      document.getElementById('sidebar-topic').style.display = 'block';
      document.getElementById('sidebar-topic-text').textContent = topic;
    }

    function hideWaiting() {
      document.getElementById('waiting-overlay').classList.add('hidden');
    }

    function enableInput() {
      if (role === 'debater') {
        document.getElementById('msg-input').disabled = false;
        document.getElementById('send-btn').disabled = false;
        document.getElementById('end-btn').disabled = false;
        document.getElementById('msg-input').placeholder = 'Make your argument...';
      } else {
        document.getElementById('debater-input').style.display = 'none';
        document.getElementById('spectator-note').style.display = 'block';
      }
    }

    function disableInput() {
      document.getElementById('msg-input').disabled = true;
      document.getElementById('send-btn').disabled = true;
      document.getElementById('end-btn').disabled = true;
      document.getElementById('msg-input').placeholder = 'Debate has ended';
    }

    function addMessage(msg, animate) {
      const messages = document.getElementById('messages');
      const div = document.createElement('div');

      let cls = 'msg system';
      if (msg.type === 'judge' || msg.type === 'verdict') cls = 'msg judge';
      else if (msg.type === 'message') {
        cls = msg.username === username ? 'msg mine' : 'msg theirs';
        msgCount++;
        document.getElementById('msg-count').textContent = msgCount;
      }

      div.className = cls;
      if (!animate) div.style.animation = 'none';

      const time = new Date(msg.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

      if (msg.type === 'message') {
        div.innerHTML = `
          <div class="msg-header">
            <span class="msg-username">${msg.username}</span>
            <span>${time}</span>
          </div>
          <div class="msg-bubble">${escapeHtml(msg.text)}</div>
        `;
      } else if (msg.type === 'judge') {
        div.innerHTML = `
          <div class="msg-header">
            <span class="msg-username">⚖️ AI Judge</span>
            <span>${time}</span>
          </div>
          <div class="msg-bubble">${escapeHtml(msg.text)}</div>
        `;
      } else if (msg.type === 'verdict') {
        div.innerHTML = `
          <div class="msg-header">
            <span class="msg-username" style="color:var(--gold)">⚖️ FINAL VERDICT</span>
            <span>${time}</span>
          </div>
          <div class="msg-bubble verdict-bubble">${escapeHtml(msg.text)}</div>
        `;
      } else {
        div.innerHTML = `<div class="msg-bubble">${escapeHtml(msg.text)}</div>`;
      }

      messages.appendChild(div);
      if (animate) scrollToBottom();
    }

    function addSystemMessage(text) {
      addMessage({ type: 'system', text, timestamp: Date.now() }, true);
    }

    function sendMessage() {
      const input = document.getElementById('msg-input');
      const text = input.value.trim();
      if (!text || !debateActive) return;
      socket.emit('send-message', { roomId, text });
      input.value = '';
      input.style.height = 'auto';
    }

    function endDebate() {
      if (!confirm('End the debate and get the final verdict?')) return;
      socket.emit('end-debate', { roomId });
    }

    function scrollToBottom() {
      const messages = document.getElementById('messages');
      messages.scrollTop = messages.scrollHeight;
    }

    function updateJudgeStatus(text) {
      document.getElementById('judge-status').textContent = text;
      document.getElementById('judge-status').style.color = 'var(--green)';
    }

    function updateStatusDot(cls, text) {
      const dot = document.getElementById('status-dot');
      dot.className = 'status-dot ' + cls;
      document.getElementById('status-text').textContent = text;
    }

    function copyCode() {
      navigator.clipboard.writeText(roomId).then(() => {
        const btn = document.querySelector('.copy-btn');
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy Code', 2000);
      });
    }

    function escapeHtml(text) {
      return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
    }

    // Auto-resize textarea
    const input = document.getElementById('msg-input');
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
  </script>
</body>
</html>
